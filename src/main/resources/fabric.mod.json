{
    "schemaVersion": 1,
    "id": "rpx",
    "version": "${version}",
    "name": "ResourcePackExtractor",
    "description": "Fabric 26.1.2 mod that allows extracting server resource packs in-game.",
    "authors": [
        "ole101"
    ],
    "contact": {},
    "license": "MIT",
    "icon": "assets/rpx/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "de.ole101.rpx.client.ResourcePackExtractorClient"
        ]
    },
    "mixins": [
        "rpx.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${loader_version}",
        "minecraft": "${minecraft_version}",
        "fabric-api": "*",
        "fabric-language-kotlin": ">=${fabric_kotlin_version}"
    }
}
